PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/legalassist
JWT_SECRET=supersecret_key_for_legalassist_session_jwt
JWT_EXPIRE=30d
FRONTEND_URL=http://localhost:5173

# Google Gemini API Key (provide your own key to enable live AI guidance)
# GEMINI_API_KEY=your_gemini_api_key_here

# Mail settings (Optional: if blank, emails will log to backend/logs/emails/)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME="LegalAssist Portal"
SMTP_FROM_EMAIL=no-reply@legalassist.com
